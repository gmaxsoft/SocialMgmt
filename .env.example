# Skopiuj ten plik do `.env` w katalogu głównym repozytorium (obok `docker-compose.yml`).
# Docker Compose wczytuje `.env` automatycznie i podstawia zmienne w `docker-compose.yml`.
#
# Windows (PowerShell): Copy-Item .env.example .env
# Unix: cp .env.example .env

# Hasło użytkownika root w kontenerze MySQL — to samo wpisz w DATABASE_URL w `server/.env`.
MYSQL_ROOT_PASSWORD=your_secure_password_here
